#!/usr/bin/env bash
set -e

# blackbox setup — merged installer
# Installs skills globally and hooks into the current project (if git repo).

RETRO_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "blackbox setup"
echo "=============="
echo ""

# 1. Symlink skills to ~/.claude/skills/
SKILLS_DIR="$HOME/.claude/skills"
mkdir -p "$SKILLS_DIR"

for skill in scorecard retro; do
    target="$SKILLS_DIR/blackbox-$skill"
    source="$RETRO_DIR/skills/$skill"
    if [ -L "$target" ] || [ -d "$target" ]; then
        echo "[skip] $skill skill already linked"
    else
        ln -s "$source" "$target"
        echo "[ok]   Linked $skill skill -> $target"
    fi
done

echo ""

# 2. If CWD is a git repo, do project setup
if git rev-parse --git-dir > /dev/null 2>&1; then
    PROJECT_DIR="$(pwd)"
    echo "Git repo detected: $PROJECT_DIR"
    echo ""

    # Copy hooks to .claude/hooks/
    HOOKS_DEST="$PROJECT_DIR/.claude/hooks"
    mkdir -p "$HOOKS_DEST"

    for hook in session_init.py track_read.py check_edit.py track_test.py check_commit.py track_safety.py session_end.py _violations.py; do
        cp "$RETRO_DIR/hooks/$hook" "$HOOKS_DEST/$hook"
        echo "[ok]   Copied $hook"
    done

    # Create sessions directory
    mkdir -p "$PROJECT_DIR/.claude/sessions"
    echo "[ok]   Created .claude/sessions/"

    # Add to .gitignore
    GITIGNORE="$PROJECT_DIR/.gitignore"
    touch "$GITIGNORE"
    for pattern in ".claude/sessions/" ".claude/hooks/"; do
        if ! grep -qF "$pattern" "$GITIGNORE" 2>/dev/null; then
            echo "$pattern" >> "$GITIGNORE"
            echo "[ok]   Added $pattern to .gitignore"
        fi
    done

    # Merge hooks into settings.local.json using Python
    SETTINGS="$PROJECT_DIR/.claude/settings.local.json"
    # Use python3 on Linux/macOS, python on Windows
    PYTHON_CMD="python3"
    command -v python3 &>/dev/null || PYTHON_CMD="python"
    $PYTHON_CMD - "$SETTINGS" << 'PYEOF'
import json
import sys

settings_path = sys.argv[1]

# Load existing settings
existing = {}
try:
    with open(settings_path, "r", encoding="utf-8") as f:
        existing = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    pass

# Define hooks config
hooks_config = {
    "SessionStart": [
        {"hooks": [{"type": "command", "command": "python .claude/hooks/session_init.py", "timeout": 3}]}
    ],
    "PreToolUse": [
        {
            "matcher": "Bash",
            "hooks": [
                {"type": "command", "command": "python .claude/hooks/check_commit.py", "timeout": 3, "statusMessage": "Checking commit compliance..."}
            ]
        },
        {
            "matcher": "Edit",
            "hooks": [
                {"type": "command", "command": "python .claude/hooks/check_edit.py", "timeout": 3, "statusMessage": "Checking edit compliance..."}
            ]
        }
    ],
    "PostToolUse": [
        {
            "matcher": "Read",
            "hooks": [{"type": "command", "command": "python .claude/hooks/track_read.py", "timeout": 2}]
        },
        {
            "matcher": "Bash",
            "hooks": [
                {"type": "command", "command": "python .claude/hooks/track_test.py", "timeout": 2},
                {"type": "command", "command": "python .claude/hooks/track_safety.py", "timeout": 2}
            ]
        }
    ],
    "Stop": [
        {"hooks": [{"type": "command", "command": "python .claude/hooks/session_end.py", "timeout": 5}]}
    ]
}

# Merge: overwrite hooks section, preserve everything else
existing["hooks"] = hooks_config

with open(settings_path, "w", encoding="utf-8") as f:
    json.dump(existing, f, indent=2)

print("[ok]   Merged hooks into", settings_path)
PYEOF

    echo ""
    echo "Project setup complete."
else
    echo "Not in a git repo — skipping project hooks setup."
    echo "Run this from a git project root to install hooks."
fi

echo ""
echo "Skills available:"
echo "  /scorecard    Show agent compliance scorecard"
echo "  /retro        Weekly retrospective and rule updates"
echo ""

# Suggest PATH addition
if ! command -v blackbox &> /dev/null; then
    echo "To add the blackbox CLI to your PATH:"
    echo "  export PATH=\"$RETRO_DIR/bin:\$PATH\""
    echo ""
fi

echo "Done."
