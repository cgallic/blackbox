#!/usr/bin/env bash
set -e

# retro-loop project setup
# Run this from the root of any project to install hooks and scripts.

RETRO_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(pwd)"

echo "retro-loop project setup"
echo "========================"
echo "Project: $PROJECT_DIR"
echo ""

# 1. Copy hooks
mkdir -p "$PROJECT_DIR/.claude/hooks"
cp "$RETRO_DIR/hooks/"*.py "$PROJECT_DIR/.claude/hooks/"
echo "[ok] Copied hooks to .claude/hooks/"

# 2. Copy scripts
mkdir -p "$PROJECT_DIR/scripts"
cp "$RETRO_DIR/scripts/backfill_sessions.py" "$PROJECT_DIR/scripts/"
cp "$RETRO_DIR/scripts/audit_sessions.py" "$PROJECT_DIR/scripts/"
echo "[ok] Copied scripts to scripts/"

# 3. Create sessions directory
mkdir -p "$PROJECT_DIR/.claude/sessions"
echo "[ok] Created .claude/sessions/"

# 4. Add to .gitignore
if [ -f "$PROJECT_DIR/.gitignore" ]; then
    if ! grep -q ".claude/sessions/" "$PROJECT_DIR/.gitignore" 2>/dev/null; then
        echo "" >> "$PROJECT_DIR/.gitignore"
        echo "# retro-loop session logs" >> "$PROJECT_DIR/.gitignore"
        echo ".claude/sessions/" >> "$PROJECT_DIR/.gitignore"
        echo "[ok] Added .claude/sessions/ to .gitignore"
    else
        echo "[skip] .claude/sessions/ already in .gitignore"
    fi
else
    echo ".claude/sessions/" > "$PROJECT_DIR/.gitignore"
    echo "[ok] Created .gitignore with .claude/sessions/"
fi

# 5. Merge hooks into settings.local.json
SETTINGS="$PROJECT_DIR/.claude/settings.local.json"
HOOKS_JSON="$RETRO_DIR/hooks.json"

python3 - "$SETTINGS" "$HOOKS_JSON" <<'PYEOF'
import json
import sys
import os

settings_path = sys.argv[1]
hooks_path = sys.argv[2]

# Load existing settings or start fresh
settings = {}
if os.path.exists(settings_path):
    try:
        with open(settings_path, "r") as f:
            settings = json.load(f)
    except (json.JSONDecodeError, IOError):
        pass

# If hooks already exist, don't overwrite
if "hooks" in settings:
    print("[skip] Hooks already in settings.local.json -- merge manually if needed")
    sys.exit(0)

# Load hooks template
with open(hooks_path, "r") as f:
    hooks = json.load(f)

settings["hooks"] = hooks

os.makedirs(os.path.dirname(settings_path), exist_ok=True)
with open(settings_path, "w") as f:
    json.dump(settings, f, indent=2)
    f.write("\n")

print("[ok] Merged hooks into settings.local.json")
PYEOF

echo ""
echo "Project setup complete!"
echo ""
echo "Hooks active:"
echo "  SessionStart  -> session_init.py (reset tracking)"
echo "  PostToolUse   -> track_read.py (log file reads)"
echo "  PostToolUse   -> check_edit.py (verify read-before-edit)"
echo "  PostToolUse   -> track_test.py (log test runs)"
echo "  PreToolUse    -> check_commit.py (verify test-before-commit)"
echo "  PostToolUse   -> track_safety.py (log destructive commands)"
echo "  Stop          -> session_end.py (aggregate compliance)"
echo ""
echo "Commands:"
echo "  python scripts/audit_sessions.py          # View audit report"
echo "  python scripts/backfill_sessions.py       # Backfill from history"
echo "  /retro-session                            # Score a session"
echo "  /retro-dev                                # Weekly retrospective"
